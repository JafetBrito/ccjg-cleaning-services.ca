---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// El número de Timmins que definimos
const phone = "+17052886527";
---

<header id="main-navbar" class="fixed top-0 left-0 w-full z-[100] transition-all duration-300 bg-transparent border-b border-transparent">
  <div class="container mx-auto px-6 h-20 flex items-center justify-between">
    
    <a href="/" class="relative z-50 text-white font-black text-2xl tracking-widest drop-shadow-md bg-black/60 backdrop-blur-sm px-4 py-2 rounded-lg border border-white/10 hover:bg-black/80 transition-colors duration-300">
      CCJG<span class="text-ccjg-cyan">.</span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      <a href="#servicios" class="text-xs text-gray-200 hover:text-white hover:text-shadow-glow transition-all uppercase tracking-[0.2em] font-bold">{t('nav.services')}</a>
      <a href="#filosofia" class="text-xs text-gray-200 hover:text-white hover:text-shadow-glow transition-all uppercase tracking-[0.2em] font-bold">{t('nav.philosophy')}</a>
      <a href="#galeria" class="text-xs text-gray-200 hover:text-white hover:text-shadow-glow transition-all uppercase tracking-[0.2em] font-bold">{t('nav.gallery')}</a>
      
      <a href={`tel:${phone}`} class="ml-4 px-6 py-2.5 bg-ccjg-cyan text-white text-[10px] font-black uppercase tracking-widest rounded-sm hover:bg-white hover:text-ccjg-dark transition-all duration-300 shadow-[0_0_15px_rgba(0,180,216,0.4)]">
        {t('nav.call')}
      </a>
    </nav>

    <button id="mobile-menu-btn" class="md:hidden relative z-50 text-white p-2 focus:outline-none bg-black/40 backdrop-blur-sm rounded-lg border border-white/10">
      <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 absolute top-2 left-2 opacity-0 transition-opacity duration-300 scale-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

  </div>

  <div id="mobile-menu" class="fixed inset-0 bg-[#030712]/95 backdrop-blur-xl flex flex-col items-center justify-center gap-10 opacity-0 pointer-events-none transition-opacity duration-300 h-screen w-screen z-40">
    <a href="#servicios" class="mobile-link text-3xl text-gray-300 hover:text-white transition-colors uppercase tracking-[0.2em] font-black">{t('nav.services')}</a>
    <a href="#filosofia" class="mobile-link text-3xl text-gray-300 hover:text-white transition-colors uppercase tracking-[0.2em] font-black">{t('nav.philosophy')}</a>
    <a href="#galeria" class="mobile-link text-3xl text-gray-300 hover:text-white transition-colors uppercase tracking-[0.2em] font-black">{t('nav.gallery')}</a>
    
    <a href={`tel:${phone}`} class="mt-8 px-10 py-5 bg-ccjg-cyan text-white text-sm font-black uppercase tracking-[0.2em] rounded-sm shadow-[0_0_20px_rgba(0,180,216,0.4)]">
      {t('nav.call')}
    </a>
  </div>
</header>

<script>
  const header = document.getElementById('main-navbar');
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  let isMenuOpen = false;

  // Lógica: Efecto Cristal al hacer Scroll
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header.classList.replace('bg-transparent', 'bg-black/80');
      header.classList.replace('border-transparent', 'border-white/10');
      header.classList.add('backdrop-blur-md');
    } else {
      header.classList.replace('bg-black/80', 'bg-transparent');
      header.classList.replace('border-white/10', 'border-transparent');
      header.classList.remove('backdrop-blur-md');
    }
  });

  // Lógica: Abrir/Cerrar Menú Móvil
  const toggleMenu = () => {
    isMenuOpen = !isMenuOpen;
    
    if (isMenuOpen) {
      // Mostrar menú
      mobileMenu.classList.remove('pointer-events-none');
      mobileMenu.classList.replace('opacity-0', 'opacity-100');
      
      // Animar iconos
      menuIcon.classList.add('opacity-0', 'scale-50');
      closeIcon.classList.remove('opacity-0', 'scale-50');
      closeIcon.classList.add('opacity-100', 'scale-100');
      
      // Bloquear scroll de la página de fondo
      document.body.style.overflow = 'hidden'; 
    } else {
      // Ocultar menú
      mobileMenu.classList.add('pointer-events-none');
      mobileMenu.classList.replace('opacity-100', 'opacity-0');
      
      // Animar iconos
      menuIcon.classList.remove('opacity-0', 'scale-50');
      closeIcon.classList.remove('opacity-100', 'scale-100');
      closeIcon.classList.add('opacity-0', 'scale-50');
      
      // Restaurar scroll
      document.body.style.overflow = '';
    }
  };

  menuBtn.addEventListener('click', toggleMenu);

  // Cerrar menú automáticamente al hacer clic en un enlace
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (isMenuOpen) toggleMenu();
    });
  });
</script>

<style>
  .text-shadow-glow {
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.8);
  }
</style>