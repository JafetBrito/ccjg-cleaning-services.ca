---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentYear = new Date().getFullYear();
const baseUrl = lang === 'en' ? '' : `/${lang}`;
---

<footer class="bg-[#010308] border-t border-white/5 pt-16 pb-8 overflow-hidden relative">
  <div class="absolute bottom-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-ccjg-cyan/20 to-transparent"></div>

  <div class="container mx-auto px-6 max-w-7xl relative z-10">
    
    <div class="flex flex-col md:flex-row justify-between items-start gap-10 mb-16">
      
      <div class="max-w-sm">
        <a href={`${baseUrl}/`} class="text-white font-black text-3xl tracking-widest drop-shadow-md mb-1 block">
          CCJG<span class="text-ccjg-cyan">.</span>
        </a>
        <p class="text-xs font-black tracking-[0.2em] uppercase mb-5 inline-flex items-center gap-2 bg-gradient-to-r from-ccjg-cyan to-blue-400 text-transparent bg-clip-text">
          <span class="text-sm" style="text-shadow: 0 0 10px rgba(56,178,172,0.5);">✨</span> Your Business, Our Priority
        </p>
        <p class="text-gray-500 text-sm font-light leading-relaxed">
          {t('footer.desc')}
        </p>
      </div>
      
      <div class="flex gap-10 md:gap-20">
        <div class="flex flex-col gap-4">
          <span class="text-white font-bold uppercase tracking-widest text-[10px] mb-2 opacity-50 flex items-center gap-2">
            🏢 {t('footer.company')}
          </span>
          <a href="#filosofia" class="group text-gray-400 hover:text-ccjg-cyan text-xs font-medium uppercase tracking-wider transition-colors flex items-center gap-2">
            <span class="opacity-50 group-hover:opacity-100 transition-opacity">💡</span> {t('nav.philosophy')}
          </a>
          <a href="#impacto" class="group text-gray-400 hover:text-ccjg-cyan text-xs font-medium uppercase tracking-wider transition-colors flex items-center gap-2">
            <span class="opacity-50 group-hover:opacity-100 transition-opacity">🌍</span> {t('impact.bg')}
          </a>
        </div>
        <div class="flex flex-col gap-4">
          <span class="text-white font-bold uppercase tracking-widest text-[10px] mb-2 opacity-50 flex items-center gap-2">
            🔍 {t('footer.explore')}
          </span>
          <a href="#servicios" class="group text-gray-400 hover:text-ccjg-cyan text-xs font-medium uppercase tracking-wider transition-colors flex items-center gap-2">
            <span class="opacity-50 group-hover:opacity-100 transition-opacity">🧽</span> {t('nav.services')}
          </a>
          <a href="#galeria" class="group text-gray-400 hover:text-ccjg-cyan text-xs font-medium uppercase tracking-wider transition-colors flex items-center gap-2">
            <span class="opacity-50 group-hover:opacity-100 transition-opacity">📸</span> {t('footer.projects')}
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-600 text-[10px] font-mono tracking-widest uppercase text-center md:text-left">
        &copy; {currentYear} CCJG Cleaning Services. {t('footer.rights')}
      </p>
      
      <p class="text-gray-700 text-[10px] font-mono tracking-widest uppercase flex items-center gap-2">
        {t('footer.engineered')} 
        <a href="https://rubicsdigitalsolutions.ca" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-ccjg-cyan transition-colors font-bold flex items-center gap-1 group">
          Rubic's Digital Solutions
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </p>
    </div>

  </div>
</footer>