---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="filosofia" class="relative py-24 lg:py-32 bg-[#030712] border-t border-white/5 overflow-hidden select-none">
  
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_var(--tw-gradient-stops))] from-ccjg-cyan/[0.05] via-transparent to-transparent pointer-events-none"></div>

  <div class="container mx-auto px-6 max-w-7xl relative z-10">
    <div class="flex flex-col lg:flex-row gap-16 lg:gap-20 items-center lg:items-start">
      
      <div class="w-full lg:w-5/12 lg:sticky lg:top-32">
        
        <span class="inline-flex items-center gap-2 px-4 py-1.5 border border-ccjg-cyan/30 rounded-full bg-ccjg-dark/40 backdrop-blur-md text-ccjg-cyan font-bold tracking-[0.3em] uppercase text-[10px] mb-8 shadow-[0_0_15px_rgba(0,180,216,0.15)]">
          <span class="w-1.5 h-1.5 rounded-full bg-ccjg-cyan animate-pulse"></span>
          {t('about.standard')}
        </span>
        
        <h2 class="text-5xl sm:text-6xl lg:text-7xl font-black text-white tracking-tighter leading-[0.95] mb-8 crisp-shadow">
          {t('about.title1')} <br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-br from-gray-200 to-gray-600">{t('about.title2')}</span>
        </h2>
        
        <p class="text-gray-300 text-lg md:text-xl font-light leading-relaxed mb-8">
          {t('about.desc')}
        </p>

        <div class="relative pl-6 py-2 mt-10">
          <div class="absolute left-0 top-0 bottom-0 w-[2px] bg-gradient-to-b from-ccjg-cyan via-ccjg-cyan/50 to-transparent"></div>
          
          <p class="text-white/90 font-medium italic text-lg md:text-xl leading-relaxed relative z-10">
            {t('about.quote')}
          </p>
        </div>
      </div>

      <div class="w-full lg:w-7/12 grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6" id="cards-container">
        
        <div class="glow-card relative bg-[#060D1A]/60 backdrop-blur-md border border-white/5 rounded-3xl p-8 overflow-hidden group">
          <div class="card-spotlight absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none" style="background: radial-gradient(600px circle at var(--x) var(--y), rgba(0,180,216,0.12), transparent 40%);"></div>
          
          <div class="absolute top-6 right-6 w-12 h-12 bg-white/5 border border-white/10 rounded-full flex items-center justify-center text-xl shadow-lg group-hover:border-ccjg-cyan/50 group-hover:bg-ccjg-cyan/10 transition-all duration-500 group-hover:scale-110 group-hover:-rotate-12" style="font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', sans-serif;">
            🛡️
          </div>

          <div class="relative z-10 mt-6">
            <span class="text-ccjg-cyan/50 font-mono text-xs font-bold mb-3 block group-hover:text-ccjg-cyan transition-colors duration-300 tracking-widest">{t('about.card1.num')}</span>
            <h3 class="text-2xl font-black text-white mb-3 tracking-tight group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-white group-hover:to-ccjg-cyan transition-all duration-300">{t('about.card1.title')}</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-light">{t('about.card1.desc')}</p>
          </div>
        </div>

        <div class="glow-card relative bg-[#060D1A]/60 backdrop-blur-md border border-white/5 rounded-3xl p-8 overflow-hidden group mt-0 md:mt-12">
          <div class="card-spotlight absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none" style="background: radial-gradient(600px circle at var(--x) var(--y), rgba(0,180,216,0.12), transparent 40%);"></div>
          
          <div class="absolute top-6 right-6 w-12 h-12 bg-white/5 border border-white/10 rounded-full flex items-center justify-center text-xl shadow-lg group-hover:border-ccjg-cyan/50 group-hover:bg-ccjg-cyan/10 transition-all duration-500 group-hover:scale-110 group-hover:rotate-12" style="font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', sans-serif;">
            ⚡
          </div>

          <div class="relative z-10 mt-6">
            <span class="text-ccjg-cyan/50 font-mono text-xs font-bold mb-3 block group-hover:text-ccjg-cyan transition-colors duration-300 tracking-widest">{t('about.card2.num')}</span>
            <h3 class="text-2xl font-black text-white mb-3 tracking-tight group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-white group-hover:to-ccjg-cyan transition-all duration-300">{t('about.card2.title')}</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-light">{t('about.card2.desc')}</p>
          </div>
        </div>

        <div class="glow-card relative bg-[#060D1A]/60 backdrop-blur-md border border-white/5 rounded-3xl p-8 overflow-hidden group">
          <div class="card-spotlight absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none" style="background: radial-gradient(600px circle at var(--x) var(--y), rgba(0,180,216,0.12), transparent 40%);"></div>
          
          <div class="absolute top-6 right-6 w-12 h-12 bg-white/5 border border-white/10 rounded-full flex items-center justify-center text-xl shadow-lg group-hover:border-ccjg-cyan/50 group-hover:bg-ccjg-cyan/10 transition-all duration-500 group-hover:scale-110 group-hover:-rotate-12" style="font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', sans-serif;">
            ✨
          </div>

          <div class="relative z-10 mt-6">
            <span class="text-ccjg-cyan/50 font-mono text-xs font-bold mb-3 block group-hover:text-ccjg-cyan transition-colors duration-300 tracking-widest">{t('about.card3.num')}</span>
            <h3 class="text-2xl font-black text-white mb-3 tracking-tight group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-white group-hover:to-ccjg-cyan transition-all duration-300">{t('about.card3.title')}</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-light">{t('about.card3.desc')}</p>
          </div>
        </div>

        <div class="glow-card relative border border-ccjg-cyan/30 bg-gradient-to-b from-ccjg-cyan/20 to-transparent rounded-3xl p-8 overflow-hidden group mt-0 md:mt-12 shadow-[0_0_30px_rgba(0,180,216,0.1)]">
          <div class="card-spotlight absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none" style="background: radial-gradient(600px circle at var(--x) var(--y), rgba(255,255,255,0.15), transparent 40%);"></div>
          
          <div class="absolute top-6 right-6 w-12 h-12 bg-ccjg-cyan/20 border border-ccjg-cyan/50 rounded-full flex items-center justify-center text-xl shadow-lg group-hover:scale-125 group-hover:rotate-12 transition-all duration-500" style="font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', sans-serif;">
            🏆
          </div>

          <div class="relative z-10 flex flex-col h-full justify-between mt-6">
            <div>
              <span class="text-white/60 font-mono text-xs font-bold mb-3 block tracking-widest">{t('about.card4.num')}</span>
              <h3 class="text-4xl md:text-5xl font-black text-white mb-3 tracking-tighter drop-shadow-lg" set:html={t('about.card4.title').replace(' ', '<br/>')}></h3>
            </div>
            <p class="text-ccjg-cyan/90 text-sm leading-relaxed font-medium mt-6">
              {t('about.card4.desc')}
            </p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('cards-container');
    const cards = document.querySelectorAll('.glow-card');

    if (container) {
      container.addEventListener('mousemove', (e) => {
        cards.forEach(card => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          card.style.setProperty('--x', `${x}px`);
          card.style.setProperty('--y', `${y}px`);
        });
      });
    }
  });
</script>

<style>
  .crisp-shadow {
    text-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }
  .glow-card {
    transition: border-color 0.4s ease, transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease;
  }
  .glow-card:hover {
    border-color: rgba(0, 180, 216, 0.5);
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.4), 0 0 20px rgba(0, 180, 216, 0.1);
  }
</style>