---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// 1. Botones de categorías
const categories = [
  { id: "all", label: "All Categories", emoji: "🌟" },
  { id: "commercial", label: t('gallery.p1.title'), emoji: "🪞" }, 
  { id: "common", label: t('gallery.p2.title'), emoji: "🏢" },   
  { id: "warehouse", label: t('gallery.p3.title'), emoji: "🏭" },  
  { id: "exterior", label: t('gallery.p4.title'), emoji: "🌊" },
  { id: "videos", label: "Videos", emoji: "🎥" } 
];

// 2. Galería Híbrida (LIMPIA - Con tus fotos reales mapeadas)
const galleryItems = [
  // --- TUS FOTOS REALES (Extraídas de tu directorio) ---
  { type: "image", src: "/images/gallery/ccjg-cleaning-services.ca-wax.jpg", category: "commercial", alt: "Floor Waxing Commercial" },
  { type: "image", src: "/images/gallery/ccjg-cleaning-services.ca-wax1.jpg", category: "commercial", alt: "Commercial Cleaning Wax" },
  { type: "image", src: "/images/gallery/ccjg-cleaning-services.ca-wax2.jpg", category: "common", alt: "Common Area Waxing" },
  { type: "image", src: "/images/gallery/ccjg-cleaning-services.ca-wax3.jpg", category: "common", alt: "Common Area Floor Care" },
  { type: "image", src: "/images/gallery/ccjg-cleaning-services.ca-wax4.jpg", category: "warehouse", alt: "Warehouse Floor Waxing" },
  { type: "image", src: "/images/gallery/ccjg-cleaning-services.ca-wax5.jpg", category: "warehouse", alt: "Industrial Floor Care" },
  { type: "image", src: "/images/gallery/ccjg-cleaning-services.ca-wash.jpg", category: "exterior", alt: "Exterior Power Washing" },
  { type: "image", src: "/images/gallery/ccjg-cleaning-services.ca-wash2.jpg", category: "exterior", alt: "Exterior Cleaning Service" },
  
  // --- TUS VIDEOS (Que ya funcionan perfecto) ---
  { type: "video", src: "/images/gallery/videos/WhatsApp%20Video%202026-04-24%20at%206.23.14%20PM.mp4", category: "videos", alt: "Cleaning Process 1" },
  { type: "video", src: "/images/gallery/videos/WhatsApp%20Video%202026-04-24%20at%206.23.14%20PM%20(1).mp4", category: "videos", alt: "Cleaning Process 2" },
  { type: "video", src: "/images/gallery/videos/WhatsApp%20Video%202026-04-24%20at%206.23.14%20PM%20(2).mp4", category: "videos", alt: "Cleaning Process 3" }
];
---

<section id="galeria" class="relative py-20 bg-[#010308] border-t border-white/5">
  <div class="container mx-auto px-6 max-w-7xl relative z-10">
    
    <div class="flex flex-col md:flex-row items-end justify-between mb-8 gap-6">
      <div class="max-w-2xl">
        <span class="inline-block px-4 py-1.5 border border-ccjg-cyan/30 rounded-full bg-ccjg-dark/20 text-ccjg-cyan font-bold tracking-[0.3em] uppercase text-[10px] mb-6">
          {t('gallery.badge')}
        </span>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white tracking-tighter leading-[0.95] uppercase">
          {t('gallery.title1')} <br/>
          <span class="text-gray-500">{t('gallery.title2')}</span>
        </h2>
      </div>
    </div>

    <div class="flex items-center justify-center md:justify-start py-4 md:py-8 flex-wrap gap-2 md:gap-3">
      {categories.map((cat) => (
        <button 
          type="button" 
          data-filter={cat.id}
          class="filter-btn text-gray-400 border border-white/10 hover:border-ccjg-cyan hover:text-white bg-[#030712] focus:ring-4 focus:outline-none focus:ring-ccjg-cyan/20 rounded-xl text-xs md:text-sm font-black uppercase tracking-wider px-5 py-2.5 text-center transition-all duration-300"
        >
          <span class="mr-2 text-base" style="font-family: 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji', sans-serif;">{cat.emoji}</span> 
          {cat.label}
        </button>
      ))}
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4" id="gallery-grid">
      {galleryItems.map((item) => (
        <div class="gallery-item transition-all duration-500 ease-in-out" data-category={item.category}>
          <div class="relative group cursor-pointer w-full h-full rounded-xl overflow-hidden shadow-lg border border-white/5 hover:border-ccjg-cyan/50 transition-all duration-300 bg-gray-900" onclick={`openSingleModal('${item.src}', '${item.type}')`}>
            
            {item.type === 'image' ? (
              <img 
                class="h-full w-full aspect-square object-cover group-hover:scale-[1.05] transition-all duration-500" 
                src={item.src} 
                alt={item.alt}
                loading="lazy"
                onerror="this.onerror=null; this.src='/images/logo.png'; this.classList.add('opacity-20', 'object-contain', 'p-8');" 
              />
            ) : (
              <div class="relative h-full w-full aspect-square overflow-hidden group-hover:scale-[1.05] transition-all duration-500">
                <video 
                  class="h-full w-full object-cover" 
                  src={item.src} 
                  muted loop playsinline autoplay
                ></video>
                <div class="absolute inset-0 flex items-center justify-center z-10 pointer-events-none">
                  <div class="bg-black/40 backdrop-blur-sm p-3 rounded-full border border-white/30 text-white shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 pl-1 opacity-90" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
                    </svg>
                  </div>
                </div>
              </div>
            )}
            
            <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center backdrop-blur-[2px] z-20">
              <div class="bg-ccjg-cyan/20 p-3 rounded-full border border-ccjg-cyan/50 text-white transform scale-50 group-hover:scale-100 transition-transform duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                </svg>
              </div>
            </div>

          </div>
        </div>
      ))}
    </div>

  </div>

  <div id="single-image-modal" class="fixed inset-0 w-screen h-[100dvh] z-[9999] bg-[#010308]/95 backdrop-blur-xl opacity-0 pointer-events-none transition-opacity duration-300">
    
    <button id="close-single-modal" class="absolute top-4 right-4 md:top-8 md:right-8 z-[10000] bg-[#030712]/80 border-2 border-white/20 hover:border-ccjg-cyan text-white hover:text-ccjg-cyan p-3 md:p-4 rounded-full transition-all cursor-pointer shadow-xl group">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-8 md:w-8 group-hover:rotate-90 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="w-full h-full flex items-center justify-center p-4 md:p-12 cursor-zoom-out" id="modal-backdrop-area">
      <img id="single-modal-img" src="" alt="Zoom" class="hidden max-h-[90vh] max-w-full object-contain drop-shadow-[0_20px_50px_rgba(0,0,0,0.8)] rounded-lg transform scale-95 opacity-0 transition-all duration-300 cursor-default" />
      
      <video id="single-modal-video" src="" controls muted class="hidden max-h-[90vh] max-w-full object-contain drop-shadow-[0_20px_50px_rgba(0,0,0,0.8)] rounded-lg transform scale-95 opacity-0 transition-all duration-300 cursor-default"></video>
    </div>
    
  </div>
</section>

<script is:inline>
  const singleModal = document.getElementById('single-image-modal');
  const singleImg = document.getElementById('single-modal-img');
  const singleVideo = document.getElementById('single-modal-video');
  const closeSingleBtn = document.getElementById('close-single-modal');
  const backdropArea = document.getElementById('modal-backdrop-area');

  function openSingleModal(src, type) {
    if(!singleModal) return;
    
    singleModal.classList.remove('pointer-events-none', 'opacity-0');
    document.body.style.overflow = 'hidden'; 

    if (type === 'video') {
      singleImg.classList.add('hidden');
      singleVideo.classList.remove('hidden');
      singleVideo.src = src;
      singleVideo.muted = true; // Aseguramos por JS que inicie silenciado
      singleVideo.play();
      setTimeout(() => {
        singleVideo.classList.remove('scale-95', 'opacity-0');
        singleVideo.classList.add('scale-100', 'opacity-100');
      }, 50);
    } else {
      singleVideo.classList.add('hidden');
      singleVideo.pause();
      singleImg.classList.remove('hidden');
      singleImg.src = src;
      setTimeout(() => {
        singleImg.classList.remove('scale-95', 'opacity-0');
        singleImg.classList.add('scale-100', 'opacity-100');
      }, 50);
    }
  }

  function closeSingleModal() {
    if(!singleModal) return;

    singleImg.classList.remove('scale-100', 'opacity-100');
    singleImg.classList.add('scale-95', 'opacity-0');
    singleVideo.classList.remove('scale-100', 'opacity-100');
    singleVideo.classList.add('scale-95', 'opacity-0');
    
    singleVideo.pause();

    setTimeout(() => {
      singleModal.classList.add('pointer-events-none', 'opacity-0');
      document.body.style.overflow = ''; 
      singleImg.src = ''; 
      singleVideo.src = ''; 
      singleImg.classList.add('hidden');
      singleVideo.classList.add('hidden');
    }, 300);
  }

  if(closeSingleBtn) closeSingleBtn.addEventListener('click', closeSingleModal);
  
  if(backdropArea) {
    backdropArea.addEventListener('click', (e) => {
      if (e.target === backdropArea) closeSingleModal();
    });
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && singleModal && !singleModal.classList.contains('opacity-0')) {
      closeSingleModal();
    }
  });

  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const galleryItems = document.querySelectorAll('.gallery-item');

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        
        filterButtons.forEach(btn => {
          btn.classList.remove('border-ccjg-cyan', 'text-white', 'bg-ccjg-cyan/10');
          btn.classList.add('border-white/10', 'text-gray-400', 'bg-[#030712]');
        });

        button.classList.remove('border-white/10', 'text-gray-400', 'bg-[#030712]');
        button.classList.add('border-ccjg-cyan', 'text-white', 'bg-ccjg-cyan/10');

        const filterValue = button.getAttribute('data-filter');

        galleryItems.forEach(item => {
          const itemCategory = item.getAttribute('data-category');
          
          if (filterValue === 'all' || filterValue === itemCategory) {
            item.style.display = 'block';
            setTimeout(() => {
              item.style.opacity = '1';
              item.style.transform = 'scale(1)';
            }, 50);
          } else {
            item.style.opacity = '0';
            item.style.transform = 'scale(0.9)';
            setTimeout(() => {
              item.style.display = 'none';
            }, 300);
          }
        });
      });
    });

    if (filterButtons.length > 0) {
      filterButtons[0].click();
    }
  });
</script>